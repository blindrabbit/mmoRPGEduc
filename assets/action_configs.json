      "onTrigger": {
        "eventName": "openShop",
        "eventData": {
          "npcId": "merchant_01",
          "shopType": "general"
        }
      }
    },
    {
      "id": "lever_door_opener",
      "type": "item",
      "spriteId": 7000,
      "action": 2,
      "effects": {
        "setStorage": {
          "key": "door_opened",
          "value": 1

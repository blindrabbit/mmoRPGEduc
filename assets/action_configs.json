      "type": "item",
      "spriteId": 1800,
      "action": 4,
      "effects": {
        "teleportTo": {
          "x": 200,
          "y": 250,
          "z": 7
        },
        "playEffect": "teleport_blue"
      },
      "messages": {
        "success": "Você foi teleportado pela magia azul!"
      }
    },
    {
      "id": "stairs_up_1",
      "type": "item",

        "floorChange": -1
      },
      "messages": {
        "success": "Subindo escada..."
      }
    },
    {
      "id": "trap_fire_damage",
      "type": "position",
      "x": 180,
      "y": 220,
      "z": 7,
      "conditions": {
        "distance": 0
      },
      "effects": {
        "damage": {
          "amount": 25,
          "type": "fire"
        },
        "playEffect": "fire_hit"
      },
      "messages": {
        "success": "Você pisou em uma armadilha de fogo! -25 HP"
      }
    },
    {
      "id": "healing_shrine",
      "type": "item",
      "spriteId": 8500,

{
  "rules": {
    ".read": true,
    ".write": false,

    "online_players": {
      "$playerId": {
        ".read": true,
        // ✅ Desenvolvimento: permite escrita (remover em produção)
        // ✅ Produção: usar "auth != null && (auth.uid === $playerId || ...)"
        ".write": true,

        // ✅ Campos de administração são SOMENTE leitura (cliente não pode modificar)
        "isAdmin": { ".validate": "false" },
        "isGM": { ".validate": "false" },
        "role": { ".validate": "false" },
        "appearance": {
          "isAdmin": { ".validate": "false" },
          "$other": { ".validate": true }
        },

        // ✅ Valida coordenadas com limites do mapa
        "x": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "y": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "z": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 15)"
        },
        "direcao": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^(frente|costas|lado|lado-esquerdo)$/))"
        },

        // ✅ Valida velocidade (anti-speed-hack)
        "speed": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 600)"
        },

        // ✅ Valida timestamps
        "lastMoveTime": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= now)"
        },
        "lastAttack": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= now)"
        },
        "lastAiTick": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= now)"
        },
        "lastSeen": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= now)"
        },

        // ✅ Valida stats com limites razoáveis
        "stats": {
          "hp": {
            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 200000)"
          },
          "maxHp": {
            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 200000)"
          },
          "mp": {
            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 200000)"
          },
          "maxMp": {
            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 200000)"
          },
          "$other": {
            ".validate": true
          }
        },
        "$other": {
          ".validate": true
        }
      }
    },

    "players_data": {
      "$playerId": {
        ".read": true,
        ".write": "auth != null && auth.uid === $playerId",

        "x": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "y": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "z": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 15)"
        },
        "direcao": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^(frente|costas|lado|lado-esquerdo)$/))"
        },
        "speed": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 600)"
        },
        "spawnX": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "spawnY": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "spawnZ": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 15)"
        },
        "stats": {
          "hp": {
            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 200000)"
          },
          "maxHp": {
            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 200000)"
          },
          "mp": {
            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 200000)"
          },
          "maxMp": {
            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 200000)"
          },
          "$other": {
            ".validate": true
          }
        },
        "$other": {
          ".validate": true
        }
      }
    },

    "world_entities": {
      "$monsterId": {
        ".read": true,
        ".write": "auth != null",

        "x": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "y": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "z": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 15)"
        },
        "direcao": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^(frente|costas|lado|lado-esquerdo)$/))"
        },
        "speed": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 600)"
        },
        "type": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^(monster|corpse)$/))"
        },
        "stats": {
          "hp": {
            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 200000)"
          },
          "maxHp": {
            ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 200000)"
          },
          "$other": {
            ".validate": true
          }
        },
        "$other": {
          ".validate": true
        }
      }
    },

    "world_effects": {
      "$effectId": {
        ".read": true,
        ".write": "auth != null",

        "x": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "y": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "z": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 15)"
        },
        "startTime": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)"
        },
        "expiry": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)"
        },
        "effectDuration": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 86400000)"
        },
        "fieldDuration": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 86400000)"
        },
        "effectId": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)"
        },
        "fieldId": {
          ".validate": "!newData.exists() || newData.val() === null || (newData.isNumber() && newData.val() >= 0)"
        },
        "$other": {
          ".validate": true
        }
      }
    },

    "world_fields": {
      "$fieldId": {
        ".read": true,
        ".write": "auth != null",

        "x": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "y": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "z": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 15)"
        },
        "damage": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 200000)"
        },
        "startTime": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)"
        },
        "expiry": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)"
        },
        "tickRate": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 50 && newData.val() <= 60000)"
        },
        "fieldDuration": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 86400000)"
        },
        "fieldId": {
          ".validate": "!newData.exists() || newData.val() === null || (newData.isNumber() && newData.val() >= 0)"
        },
        "effectId": {
          ".validate": "!newData.exists() || newData.val() === null || (newData.isNumber() && newData.val() >= 0)"
        },
        "lastTick": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)"
        },
        "$other": {
          ".validate": true
        }
      }
    },

    "player_actions": {
      "$actionId": {
        ".read": true,
        // ✅ Desenvolvimento: permite escrita sem auth (remover em produção)
        // ✅ Produção: usar "auth != null && (!newData.child('playerId').exists() || newData.child('playerId').val() === auth.uid)"
        ".write": true,

        // ✅ Valida campos obrigatórios
        "id": { ".validate": "newData.isString()" },
        "playerId": { ".validate": "newData.isString()" },

        // ✅ Lista branca de tipos de ação permitidos
        "type": {
          ".validate": "newData.isString() && newData.val().matches(/^(attack|spell|move|item|map_tile_pickup|toggle_door|change_floor|allocateStat)$/)"
        },

        // ✅ Valida timestamp e expiração
        "ts": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "expiresAt": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() < now + 60000"
        },

        // ✅ Valida campos opcionais específicos
        "targetId": {
          ".validate": "!newData.exists() || newData.val() === null || newData.isString()"
        },
        "spellId": {
          ".validate": "!newData.exists() || newData.val() === null || newData.isString()"
        },
        "x": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "y": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "z": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 15)"
        },
        "direcao": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^(frente|costas|lado|lado-esquerdo)$/))"
        },
        "source": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().matches(/^(input|keyboard|admin_|worldengine|player-actions|autowalk)$/))"
        },

        // ✅ REJEITA campos não autorizados
        "$other": { ".validate": false }
      }
    },

    "world_state": {
      ".read": true,
      ".write": "auth != null"
    },

    "monster_templates": {
      ".read": true,
      ".write": "auth != null"
    },

    "world_tiles": {
      ".read": true,
      ".write": "auth != null"
    },

    "world_tiles_data": {
      ".read": true,
      ".write": "auth != null"
    },

    "world_items": {
      "$itemId": {
        ".read": true,
        // ✅ APENAS server (worldEngine) pode criar itens via skipRangeCheck=false
        // Cliente NUNCA pode definir skipRangeCheck=true
        ".write": "auth != null && (!newData.child('skipRangeCheck').exists() || newData.child('skipRangeCheck').val() === false)",
        "skipRangeCheck": { ".validate": "false" },
        // ✅ Valida campos críticos de itens do mapa
        "fromMap": {
          ".validate": "!newData.exists() || newData.isBoolean()"
        },
        "sourceCoord": {
          ".validate": "!newData.exists() || newData.isString()"
        },
        "unique_id": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "tileId": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() > 0)"
        },
        "x": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "y": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= -8192 && newData.val() <= 8192)"
        },
        "z": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0 && newData.val() <= 15)"
        },
        "quantity": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 1000)"
        },
        "expiresAt": {
          ".validate": "!newData.exists() || (newData.isNumber() && newData.val() >= 0)"
        },
        "$other": { ".validate": true }
      }
    },

    "accounts": {
      "$accountId": {
        ".read": true,
        ".write": "auth != null && auth.uid === $accountId",
        "isAdmin": { ".validate": "false" },
        "isGM": { ".validate": "false" },
        "role": { ".validate": "newData.val() === 'player'" },
        "$other": { ".validate": true }
      }
    }
  }
}
